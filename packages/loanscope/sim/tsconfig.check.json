{
  "extends": "@config/typescript/mortgage-lib.json",
  "compilerOptions": {
    "rootDir": "..",
    "paths": {
      "@loanscope/calculations": ["../calculations/src/index.ts"],
      "@loanscope/calculations/*": ["../calculations/src/*"],
      "@loanscope/domain": ["../domain/src/index.ts"],
      "@loanscope/domain/*": ["../domain/src/*"],
      "@loanscope/engine": ["../engine/src/index.ts"],
      "@loanscope/engine/*": ["../engine/src/*"],
      "@loanscope/graph": ["../graph/src/index.ts"],
      "@loanscope/graph/*": ["../graph/src/*"],
      "@loanscope/math": ["../math/src/index.ts"],
      "@loanscope/math/*": ["../math/src/*"],
      "@loanscope/program-rules": ["../program-rules/src/index.ts"],
      "@loanscope/program-rules/*": ["../program-rules/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
