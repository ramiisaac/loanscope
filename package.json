{
  "name": "loanscope",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "author": "Rami Isaac <raisaac@icloud.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ramiisaac/loanscope"
  },
  "homepage": "https://github.com/ramiisaac/loanscope#readme",
  "bugs": {
    "url": "https://github.com/ramiisaac/loanscope/issues"
  },
  "keywords": [],
  "scripts": {
    "build": "turbo build",
    "build:loanscope": "turbo build --filter @loanscope/*",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "typecheck:loanscope": "turbo typecheck --filter @loanscope/*",
    "lint": "turbo lint",
    "lint:loanscope": "turbo lint --filter @loanscope/*",
    "test": "turbo test",
    "test:loanscope": "turbo test --filter @loanscope/*",
    "commit": "cz",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "loanscope": "node packages/loanscope/cli/dist/index.js",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky",
    "clean": "turbo clean && rimraf node_modules/.cache",
    "clean:dist": "turbo clean",
    "clean:all": "rimraf node_modules apps/*/node_modules packages/*/node_modules packages/*/*/node_modules .turbo apps/*/.turbo packages/*/.turbo packages/*/*/.turbo",
    "reset": "pnpm clean:all && pnpm install",
    "workspace:new": "bash -c 'mkdir -p workspace/$(date +%Y-%m-%d)-${1:-session} && cp examples/scenarios/${2:-10-jumbo-primary}.yaml workspace/$(date +%Y-%m-%d)-${1:-session}/scenario.yaml && echo Created workspace/$(date +%Y-%m-%d)-${1:-session}'",
    "workspace:eval": "node packages/loanscope/cli/dist/index.js evaluate --config",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:loanscope && changeset publish",
    "attw": "pnpm -r --filter '@loanscope/*' --no-bail exec attw --pack --profile esm-only"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@config/eslint": "workspace:*",
    "@config/typescript": "workspace:*",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.1",
    "@arethetypeswrong/cli": "^0.18.2"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.4.1"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.9.3"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "better-sqlite3",
      "core-js-pure",
      "esbuild",
      "sharp"
    ]
  }
}
