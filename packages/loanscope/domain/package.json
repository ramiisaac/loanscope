{
  "name": "@loanscope/domain",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "lint": "eslint .",
    "clean": "rimraf dist .turbo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@config/eslint": "workspace:*",
    "eslint": "^10.1.0",
    "vitest": "^4.1.1"
  },
  "license": "MIT",
  "author": "Rami Isaac <raisaac@icloud.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramiisaac/loanscope.git",
    "directory": "packages/loanscope/domain"
  },
  "homepage": "https://github.com/ramiisaac/loanscope#readme",
  "bugs": {
    "url": "https://github.com/ramiisaac/loanscope/issues"
  },
  "keywords": [
    "mortgage",
    "underwriting",
    "loanscope",
    "types",
    "branded-types",
    "enums"
  ],
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "description": "Branded primitives (Money, Ratio, RatePct, Months), enums, and canonical types for LoanScope mortgage underwriting. Zero runtime dependencies."
}
