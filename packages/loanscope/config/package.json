{
  "name": "@loanscope/config",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "lint": "eslint .",
    "clean": "rimraf dist .turbo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@loanscope/domain": "workspace:*",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@config/eslint": "workspace:*",
    "eslint": "^10.1.0",
    "vitest": "^4.1.1"
  },
  "license": "MIT",
  "author": "Rami Isaac <raisaac@icloud.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramiisaac/loanscope.git",
    "directory": "packages/loanscope/config"
  },
  "homepage": "https://github.com/ramiisaac/loanscope#readme",
  "bugs": {
    "url": "https://github.com/ramiisaac/loanscope/issues"
  },
  "keywords": [
    "mortgage",
    "underwriting",
    "loanscope",
    "yaml",
    "zod",
    "validation"
  ],
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "description": "YAML / JSON scenario parser with zod boundary validation for LoanScope mortgage transactions, quick-quote inputs, and simulation plans."
}
