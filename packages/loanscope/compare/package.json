{
  "name": "@loanscope/compare",
  "version": "0.1.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "lint": "eslint .",
    "clean": "rimraf dist .turbo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@loanscope/domain": "workspace:*",
    "@loanscope/engine": "workspace:*",
    "@loanscope/graph": "workspace:*",
    "decimal.js": "^10.6.0",
    "p-map": "^7.0.4"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@config/eslint": "workspace:*",
    "eslint": "^10.1.0",
    "vitest": "^4.1.1"
  },
  "license": "MIT",
  "author": "Rami Isaac <raisaac@icloud.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramiisaac/loanscope.git",
    "directory": "packages/loanscope/compare"
  },
  "homepage": "https://github.com/ramiisaac/loanscope#readme",
  "bugs": {
    "url": "https://github.com/ramiisaac/loanscope/issues"
  },
  "keywords": [
    "mortgage",
    "underwriting",
    "loanscope",
    "comparison",
    "grid",
    "goal-seek"
  ],
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "description": "Comparison grid builder, executor, and goal-seek for evaluating a LoanScope mortgage scenario across product, term, rate, LTV, occupancy, and other dimensions."
}
